# Claude Code Slack Bridge - Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Slack tokens ─────────────────────────────────────────────────────────────
# Bot Token (xoxb-...): OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# App Token (xapp-...): Settings → Socket Mode → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-token-here

# Notification target: your Slack Member ID for DM (U0123ABCDEF)
# or a channel name (#claude-code)
# Member ID: click your name in Slack → Profile → ⋯ → Copy member ID
SLACK_CHANNEL=U0123ABCDEF

# Restrict commands to yourself (recommended). Same Member ID as above.
# Leave empty to allow anyone in the workspace.
ALLOWED_SLACK_USER_ID=U0123ABCDEF

# ── tmux ─────────────────────────────────────────────────────────────────────
TMUX_SESSION=claude-work

# ── Claude Code ───────────────────────────────────────────────────────────────
CLAUDE_CMD=claude

# ── Directories ──────────────────────────────────────────────────────────────
# Shared task directory for orchestration (created automatically)
TASKS_DIR=/Users/yourname/cc-tasks

# Default upload destination when a file is attached in Slack without pane spec
UPLOAD_DIR=/Users/yourname/Projects/upload

# ── Tuning ───────────────────────────────────────────────────────────────────
# Polling interval in seconds (approval detection, task delivery)
POLL_INTERVAL=5

# Shell command timeout in seconds (/cc sh)
SH_TIMEOUT=30
